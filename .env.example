# NON-SECRET config only.  Secrets are NOT stored here.
#
# To store your Kite/Telegram secrets ENCRYPTED in your OS keyring, run:
#     python -m core.security.setup_credentials
# (hidden prompts; saved in Windows Credential Manager, never in a file or git).
#
# Copy this file to .env for the non-secret settings below (optional).

APP_TZ=Asia/Kolkata
DATABASE_URL=sqlite:///data/app.db
