# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# This file holds only placeholder NAMES so contributors know what is required.

# --- Kite Connect (https://kite.trade) ---
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret
KITE_USER_ID=your_client_id
KITE_PASSWORD=your_login_password
KITE_TOTP_SECRET=your_totp_base32_secret   # the TOTP *secret*, not a 6-digit code

# --- Telegram alerts (create a bot via @BotFather) ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Optional: Claude API for news summarization (blank = free rule-based) ---
ANTHROPIC_API_KEY=

# --- App config ---
APP_TZ=Asia/Kolkata
DATABASE_URL=sqlite:///data/app.db
